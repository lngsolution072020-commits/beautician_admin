{
  "info": {
    "_postman_id": "33333333-3333-3333-3333-333333333333",
    "name": "BeauticianApp - Beautician",
    "description": "Postman collection for Beautician APIs (appointments, location tracking, product usage).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Get Appointments (Beautician)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/appointments?page=1&limit=10&status=",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "appointments"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Accept Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/appointments/{{appointment_id}}/accept",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "appointments",
                "{{appointment_id}}",
                "accept"
              ]
            }
          }
        },
        {
          "name": "Reject Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/appointments/{{appointment_id}}/reject",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "appointments",
                "{{appointment_id}}",
                "reject"
              ]
            }
          }
        },
        {
          "name": "Start Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/appointments/{{appointment_id}}/start",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "appointments",
                "{{appointment_id}}",
                "start"
              ]
            }
          }
        },
        {
          "name": "Complete Appointment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/appointments/{{appointment_id}}/complete",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "appointments",
                "{{appointment_id}}",
                "complete"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Location Tracking",
      "item": [
        {
          "name": "Update Location",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/location/update",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "location",
                "update"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": \"{{appointment_id}}\",\n  \"lat\": 19.0600,\n  \"lng\": 72.8300\n}"
            }
          }
        },
        {
          "name": "Get Location History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/location/history?appointmentId={{appointment_id}}&page=1&limit=50",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "location",
                "history"
              ],
              "query": [
                {
                  "key": "appointmentId",
                  "value": "{{appointment_id}}"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Product Usage",
      "item": [
        {
          "name": "Record Product Usage",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{beautician_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/beautician/product-usage",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "beautician",
                "product-usage"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inventoryItemId\": \"{{inventory_id}}\",\n  \"quantityUsed\": 1\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "beautician_token",
      "value": ""
    },
    {
      "key": "appointment_id",
      "value": ""
    },
    {
      "key": "inventory_id",
      "value": ""
    }
  ]
}

